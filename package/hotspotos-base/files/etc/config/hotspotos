config system 'system'
    option brand_name 'HotspotOS'
    option brand_version '1.0.0'
    option theme 'hotspotos'
    option language 'auto'
    option hostname 'HotspotOS'
    option timezone 'UTC'
    option log_size '64'
    option log_ip ''
    option conloglevel '8'
    option cronloglevel '8'

config branding 'branding'
    option logo_path '/luci-static/hotspotos/logo.svg'
    option favicon_path '/luci-static/hotspotos/favicon.ico'
    option primary_color '#2563eb'
    option secondary_color '#1e40af'
    option company_name 'HotspotOS'
    option support_email 'support@hotspotos.com'
    option support_phone ''

config network 'network'
    option wan_proto 'dhcp'
    option lan_ip '192.168.1.1'
    option lan_netmask '255.255.255.0'
    option dhcp_start '100'
    option dhcp_limit '150'
    option dhcp_leasetime '12h'
