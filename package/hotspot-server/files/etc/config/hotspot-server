config server 'main'
    option enabled '0'
    option interface 'lan'
    option captive_portal '1'
    option portal_url 'http://192.168.1.1/hotspot/login.html'
    option session_timeout '3600'
    option idle_timeout '300'
    option bandwidth_limit_down '0'
    option bandwidth_limit_up '0'
    option allow_www '1'
    option dns_redirect '1'

config network 'network'
    option lan_interface 'br-lan'
    option lan_network '192.168.1.0/24'
    option wan_interface 'wan'

config dns 'dns'
    option redirect_all '1'
    option allowed_domains 'hotspotos.com,www.hotspotos.com'
