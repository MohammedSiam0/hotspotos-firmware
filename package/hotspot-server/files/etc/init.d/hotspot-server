#!/bin/sh /etc/rc.common
# HotspotOS Captive Portal Server

START=30
STOP=70

USE_PROCD=1

start_service() {
    local enabled
    config_load hotspot-server
    config_get_bool enabled main enabled 0

    [ "$enabled" -eq 0 ] && return 0

    # Setup nftables rules
    /usr/lib/hotspotos/nft-rules.sh setup

    # Setup DNS redirect
    /usr/lib/hotspotos/captive-portal.sh setup-dns

    procd_open_instance
    procd_set_param command /bin/sh -c "while true; do /usr/lib/hotspotos/server.sh daemon; sleep 30; done"
    procd_set_param respawn
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance

    logger -t hotspot-server "HotspotOS Server started"
}

stop_service() {
    # Cleanup nftables
    /usr/lib/hotspotos/nft-rules.sh cleanup

    logger -t hotspot-server "HotspotOS Server stopped"
}

reload_service() {
    stop
    start
}

service_triggers() {
    procd_add_reload_trigger "hotspot-server"
}
