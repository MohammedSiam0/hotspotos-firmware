config core 'main'
    option enabled '1'
    option debug '0'
    option log_level 'info'
    option database_path '/var/lib/hotspotos/hotspotos.db'
    option session_timeout '3600'
    option cleanup_interval '300'

config database 'database'
    option path '/var/lib/hotspotos/hotspotos.db'
    option max_size '10'
    option backup '1'
    option backup_interval '86400'

config logging 'logging'
    option enabled '1'
    option max_entries '10000'
    option retention_days '30'
    option log_auth '1'
    option log_sessions '1'
    option log_errors '1'
