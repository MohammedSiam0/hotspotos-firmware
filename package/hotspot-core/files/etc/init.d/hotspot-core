#!/bin/sh /etc/rc.common
# HotspotOS Core Service
# Manages database, logging, and system coordination

START=15
STOP=85

USE_PROCD=1

PROG=/usr/lib/hotspotos/core.sh
DB_PATH=/var/lib/hotspotos/hotspotos.db

start_service() {
    local enabled
    config_load hotspot-core
    config_get_bool enabled main enabled 1

    [ "$enabled" -eq 0 ] && return 0

    # Ensure database directory exists
    mkdir -p /var/lib/hotspotos

    # Initialize database if not exists
    [ ! -f "$DB_PATH" ] && /usr/lib/hotspotos/database.sh init

    # Start core daemon
    procd_open_instance
    procd_set_param command /bin/sh -c "while true; do /usr/lib/hotspotos/core.sh daemon; sleep 60; done"
    procd_set_param respawn
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance

    logger -t hotspot-core "HotspotOS Core service started"
}

stop_service() {
    logger -t hotspot-core "HotspotOS Core service stopped"
}

reload_service() {
    stop
    start
}

service_triggers() {
    procd_add_reload_trigger "hotspot-core"
}
